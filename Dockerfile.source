# ===========================================
# 多阶段构建 - 支持 amd64 + arm64
# ===========================================

# Stage 1: 构建前端
FROM node:18-alpine AS build-web
ADD . /app
WORKDIR /app/web
RUN yarn && yarn build

# Stage 2: 编译 JAR（使用 Gradle 官方镜像，支持多架构）
FROM gradle:7.6-jdk8 AS build-env
ADD . /app
WORKDIR /app
COPY --from=build-web /app/web/dist /app/src/main/resources/web
# 移除桌面UI类（服务器版不需要）
RUN rm -f src/main/java/com/htmake/reader/ReaderUIApplication.kt && \
    gradle -b cli.gradle assemble --info --no-daemon && \
    mv ./build/libs/*.jar ./build/libs/reader.jar

# Stage 3: 运行时镜像
FROM eclipse-temurin:8-jre
# 安装必要工具
RUN apt-get update && \
    apt-get install -y --no-install-recommends tini curl ca-certificates tzdata && \
    ln -fs /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    dpkg-reconfigure --frontend noninteractive tzdata && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

ENV TZ=Asia/Shanghai \
    JAVA_OPTS="-Xms128m -Xmx512m -XX:+UseG1GC"

EXPOSE 8080
ENTRYPOINT ["/usr/bin/tini", "--"]
COPY --from=build-env /app/build/libs/reader.jar /app/bin/reader.jar
CMD ["java", "-jar", "/app/bin/reader.jar"]